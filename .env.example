# ===============================================
# Meta for Developers - Instagram Graph API
# ===============================================
# Obtén tu PAGE ACCESS TOKEN en:
# https://developers.facebook.com/apps/
# → Selecciona tu app → Messenger → Settings
# → Copia el "Page Access Token" para tu página de negocio
INSTAGRAM_ACCESS_TOKEN=your_page_access_token_here

# APP SECRET: Lo encuentras en App Settings → Basic
# Úsalo para validar firmas webhook
INSTAGRAM_APP_SECRET=your_app_secret_here

# WEBHOOK VERIFY TOKEN: Token personalizado que TÚ creas
# Lo usarás cuando configures el webhook en Meta
WEBHOOK_VERIFY_TOKEN=tu_token_secreto_para_webhook

# PAGE ID: ID de tu página de Facebook (vinculada al Instagram)
# Obtén con: GET /me después de autenticarte
INSTAGRAM_PAGE_ID=your_facebook_page_id_here

# ===============================================
# Anthropic Claude API
# ===============================================
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===============================================
# Email (para notificaciones de escalado)
# ===============================================
# Tu email de Gmail
EMAIL_SENDER=tu_email@gmail.com

# Contraseña de aplicación de Gmail
# Genera en: https://myaccount.google.com/apppasswords
# (NO es tu contraseña de Gmail normal)
EMAIL_PASSWORD=tu_app_password_aqui

# ===============================================
# Configuración del servidor
# ===============================================
# Puerto donde corre Flask (por defecto 5000)
FLASK_PORT=5000

# Debug mode (cambiar a False en producción)
FLASK_DEBUG=True
